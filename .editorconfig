root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[packages/spec/fixtures/**]
# Upstream spec fixtures are treated as data — do not reformat.
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_size = unset
