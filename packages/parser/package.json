{
  "name": "@streamd/parser",
  "version": "0.2.0",
  "description": "Streaming-first markdown parser with plugin support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@streamd/config": "*",
    "@vitest/coverage-v8": "^3.2.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "markdown",
    "streaming",
    "parser",
    "plugins"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarthikMAM/streamd.git",
    "directory": "packages/parser"
  },
  "homepage": "https://github.com/KarthikMAM/streamd/tree/main/packages/parser",
  "bugs": {
    "url": "https://github.com/KarthikMAM/streamd/issues"
  },
  "author": "KarthikMAM",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
