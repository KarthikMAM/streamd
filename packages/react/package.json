{
  "name": "@streamd/react",
  "version": "0.0.1",
  "description": "React renderer for @streamd/parser token trees",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@streamd/parser": "*",
    "@streamd/plugins": "*",
    "@streamd/tokens": "*"
  },
  "devDependencies": {
    "@streamd/config": "*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0"
  },
  "keywords": [
    "markdown",
    "react",
    "renderer",
    "streamd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarthikMAM/streamd.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/KarthikMAM/streamd/tree/main/packages/react",
  "bugs": {
    "url": "https://github.com/KarthikMAM/streamd/issues"
  },
  "author": "KarthikMAM",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
