{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "noAccessKey": "error",
        "noAriaHiddenOnFocusable": "error",
        "noAriaUnsupportedElements": "error",
        "noAutofocus": "error",
        "noDistractingElements": "error",
        "noHeaderScope": "error",
        "noInteractiveElementToNoninteractiveRole": "error",
        "noLabelWithoutControl": "error",
        "noNoninteractiveElementToInteractiveRole": "error",
        "noNoninteractiveTabindex": "error",
        "noPositiveTabindex": "error",
        "noRedundantAlt": "error",
        "noRedundantRoles": "error",
        "useAltText": "error",
        "useAnchorContent": "error",
        "useAriaActivedescendantWithTabindex": "error",
        "useAriaPropsForRole": "error",
        "useButtonType": "error",
        "useFocusableInteractive": "error",
        "useHeadingContent": "error",
        "useHtmlLang": "error",
        "useIframeTitle": "error",
        "useKeyWithClickEvents": "error",
        "useKeyWithMouseEvents": "error",
        "useMediaCaption": "error",
        "useValidAnchor": "error",
        "useValidAriaProps": "error",
        "useValidAriaRole": "error",
        "useValidAriaValues": "error",
        "useValidLang": "error"
      },
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error",
        "noUndeclaredDependencies": "error",
        "noSwitchDeclarations": "error",
        "useExhaustiveDependencies": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "noNamespace": "error",
        "noNegationElse": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "useAsConstAssertion": "error",
        "useCollapsedElseIf": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": {
            "syntax": "generic"
          }
        },
        "useConst": "error",
        "useDefaultSwitchClause": "error",
        "useExplicitLengthCheck": "error",
        "useForOf": "error",
        "useFragmentSyntax": "error",
        "useImportType": "error",
        "useLiteralEnumMembers": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "conventions": [
              {
                "selector": {
                  "kind": "function"
                },
                "formats": [
                  "camelCase",
                  "PascalCase"
                ]
              },
              {
                "selector": {
                  "kind": "typeLike"
                },
                "formats": [
                  "PascalCase"
                ]
              },
              {
                "selector": {
                  "kind": "enumMember"
                },
                "formats": [
                  "PascalCase"
                ]
              }
            ]
          }
        },
        "useNumberNamespace": "error",
        "useThrowOnlyError": "error"
      },
      "suspicious": {
        "noConsole": {
          "level": "error",
          "options": {
            "allow": [
              "warn",
              "error"
            ]
          }
        },
        "noDoubleEquals": "error",
        "noEmptyBlockStatements": "error",
        "noEvolvingTypes": "error",
        "noExplicitAny": "error",
        "noMisplacedAssertion": "error",
        "useAwait": "error"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 5
          }
        },
        "noExcessiveNestedTestSuites": "error",
        "noForEach": "off",
        "useLiteralKeys": "off",
        "useDateNow": "error",
        "useSimplifiedLogicExpression": "error"
      },
      "performance": {
        "noBarrelFile": "error",
        "noReExportAll": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.config.ts",
        "**/*.config.mjs",
        "packages/config/*.ts",
        "apps/docs/**",
        "apps/react-demo/vite.config.ts",
        "apps/react-native-demo/vite.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          },
          "correctness": {
            "noUndeclaredDependencies": "off"
          },
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/parser/src/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "useForOf": "off",
            "noNonNullAssertion": "off",
            "noParameterAssign": "off",
            "useDefaultSwitchClause": "off",
            "useNamingConvention": "off",
            "useTemplate": "off",
            "useNumberNamespace": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noBannedTypes": "off"
          },
          "performance": {
            "noBarrelFile": "off"
          },
          "correctness": {
            "noSwitchDeclarations": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/html/src/render.ts",
        "packages/html/src/escape.ts",
        "packages/html/src/entities.ts",
        "packages/html/src/streaming.ts",
        "packages/react/src/render.tsx",
        "packages/react/src/components.tsx",
        "packages/react/src/escape.ts",
        "packages/react/src/entities.ts",
        "packages/react/src/theme.tsx",
        "packages/react-native/src/render.tsx",
        "packages/react-native/src/components.tsx",
        "packages/react-native/src/theme.tsx",
        "packages/plugins/src/walk.ts",
        "packages/plugins/src/builtins/heading-anchors.ts",
        "packages/plugins/src/builtins/highlight-code.ts",
        "packages/plugins/src/builtins/link-attributes.ts",
        "packages/plugins/src/builtins/sanitize.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useForOf": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "useSimplifiedLogicExpression": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/__tests__/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveNestedTestSuites": "off"
          },
          "suspicious": {
            "noMisplacedAssertion": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/scripts/**",
        "**/*.mjs"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "correctness": {
            "noUndeclaredDependencies": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "useForOf": "off",
            "useNumberNamespace": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/bench/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "useTemplate": "off",
            "useForOf": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "correctness": {
            "noUndeclaredVariables": "off",
            "noUndeclaredDependencies": "off"
          },
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "useNamingConvention": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/spec/src/skip.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/*/src/index.ts",
        "packages/*/src/**/index.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.d.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/spec/scripts/**",
        "apps/html-demo/build.mjs"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/react-native-demo/src/**"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredDependencies": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.html",
        "**/*.css"
      ],
      "linter": {
        "enabled": false
      }
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/.turbo",
      "!**/build",
      "!**/.docusaurus",
      "!**/fixtures",
      "!**/coverage",
      "!.vscode",
      "!apps/docs/static/api"
    ]
  }
}